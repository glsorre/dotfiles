{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*.env": "deny",
      "*.env.*": "deny"

    },
    "read": {
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "write": {
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  }
}
